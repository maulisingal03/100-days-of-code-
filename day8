#include <stdio.h>

long long power(int base, int exp) {
    if (exp == 0) return 1;
    if (exp == 1) return base;
    
    long long half = power(base, exp / 2);
    if (exp % 2 == 0) {
        return half * half;
    } else {
        return base * half * half;
    }
}

int main() {
    int base, exp;

    printf("Enter base: ");
    scanf("%d", &base);
    printf("Enter exponent: ");
    scanf("%d", &exp);

    if (exp < 0) {
        printf("This program currently handles positive exponents only.\n");
    } else {
        printf("%d^%d = %lld\n", base, exp, power(base, exp));
    }

    return 0;
}
