#include <stdio.h>
#include <stdlib.h>
struct Node {
    int data;
    struct Node* next;
};
void insert(struct Node** head, int data) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = data;
    newNode->next = NULL;
    if (*head == NULL) { *head = newNode; return; }
    struct Node* temp = *head;
    while (temp->next != NULL) temp = temp->next;
    temp->next = newNode;
}
struct Node* mergeSorted(struct Node* l1, struct Node* l2) {
    if (!l1) return l2;
    if (!l2) return l1;
    if (l1->data < l2->data) {
        l1->next = mergeSorted(l1->next, l2);
        return l1;
    } else {
        l2->next = mergeSorted(l1, l2->next);
        return l2;
    }
}
int main() {
    struct Node *list1 = NULL, *list2 = NULL;
    insert(&list1, 1); insert(&list1, 3); insert(&list1, 5);
    insert(&list2, 2); insert(&list2, 4); insert(&list2, 6);
    struct Node* merged = mergeSorted(list1, list2);
    printf("Merged List: ");
    while (merged) { printf("%d ", merged->data); merged = merged->next; }
    printf("\n");
    return 0;
}
