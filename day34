#include <stdio.h>
#define MAX 100
int queue[MAX], front = -1, rear = -1;
void enqueue(int item) {
    if (rear == MAX - 1) return;
    if (front == -1) front = 0;
    queue[++rear] = item;
}
void dequeue() {
    if (front == -1 || front > rear) return;
    front++;
}
int main() {
    enqueue(10); enqueue(20); enqueue(30); dequeue();
    for (int i = front; i <= rear; i++) printf("%d ", queue[i]);
    printf("\n");
    return 0;
}
