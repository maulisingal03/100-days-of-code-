#include <stdio.h>

int main() {
    int arr[100], n, key, comparisons = 0, found = 0;

    printf("Enter number of elements in array: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Enter the element to search: ");
    scanf("%d", &key);

    for (int i = 0; i < n; i++) {
        comparisons++;
        if (arr[i] == key) {
            printf("Element %d found at index %d (1-based position %d).\n", key, i, i + 1);
            found = 1;
            break;
        }
    }

    if (!found) {
        printf("Element %d not found in the array.\n", key);
    }
    
    printf("Total comparisons made: %d\n", comparisons);

    return 0;
}
