#include <stdio.h>
#include <string.h>
int main() {
    char str[100], stack[100];
    int top = -1, valid = 1;
    printf("Enter parentheses string: ");
    scanf("%s", str);
    for (int i = 0; str[i] != '\0'; i++) {
        if (str[i] == '(' || str[i] == '{' || str[i] == '[') {
            stack[++top] = str[i];
        } else {
            if (top == -1) { valid = 0; break; }
            if ((str[i] == ')' && stack[top] == '(') ||
                (str[i] == '}' && stack[top] == '{') ||
                (str[i] == ']' && stack[top] == '[')) {
                top--;
            } else {
                valid = 0;
                break;
            }
        }
    }
    if (top != -1) valid = 0;
    if (valid) printf("Valid Parentheses\n");
    else printf("Invalid Parentheses\n");
    return 0;
}
