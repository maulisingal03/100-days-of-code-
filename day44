#include <stdio.h>
#include <stdlib.h>
struct Node { int data; struct Node *left, *right; };
struct Node* createNode(int data) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = data; newNode->left = newNode->right = NULL;
    return newNode;
}
void inorder(struct Node* root) { if(root){ inorder(root->left); printf("%d ", root->data); inorder(root->right); } }
int main() {
    struct Node* root = createNode(1); root->left = createNode(2); root->right = createNode(3);
    printf("Inorder: "); inorder(root); printf("\n");
    return 0;
}
